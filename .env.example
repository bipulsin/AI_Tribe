# Application
APP_NAME=AI Tribe: Motor Damage Assessment
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ML inference: "stub" (default, no torch) or "live" (requires requirements-ml.txt)
ML_MODE=stub

# Chat NLU (local MiniLM + spaCy; weights on /mnt/ml-scratch/chat_nlu)
# CHAT_NLU_ENABLED=true
# CHAT_NLU_ROOT=/mnt/ml-scratch/chat_nlu


# Optional: OpenAI vision for lab VMMR labeling assist (/lab/vmmr-labeling).
# Without this, the tool falls back to local FGVD VMMR top-k guesses.
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini

# BYOK LLM key encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# LLM_ENCRYPTION_KEY=

# Lab labeling scratch (paperclip-vm); separate from live vmmr_corrections
# VMMR_LABEL_ROOT=/mnt/ml-scratch/vmmr_labeling
# VEHIDE_RAW_ROOT=/mnt/ml-scratch/vehide/raw

# Admin password. Optional locally (defaults to "admin").
# Required when APP_ENV=production (paperclip-vm). Never commit real values.
# ADMIN_PASSWORD=

# Session cookie
SESSION_COOKIE_NAME=ai_tribe_session
SESSION_MAX_AGE=86400

# Database (local docker-compose defaults)
DATABASE_URL=postgresql+psycopg://ai_tribe:ai_tribe@localhost:5432/ai_tribe

# Storage
UPLOAD_DIR=data/uploads
MAX_IMAGES_PER_CLAIM=10
MAX_UPLOAD_MB=25
# PROFILE_PHOTOS_DIR=data/profile_photos
# MAX_PROFILE_PHOTO_MB=2

# SMTP for admin user provisioning emails
# Prefer a domain mailbox (e.g. noreply@tradentical.com) with SPF + DKIM so
# welcome emails are less likely to land in spam. Free @gmail.com SMTP often
# gets filtered when the message contains a temporary password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=webnetin@gmail.com
# SMTP_PASSWORD=
# SMTP_FROM=webnetin@gmail.com
# SMTP_FROM_NAME=AI Tribe

# API Marketplace — encrypt re-showable partner tokens at rest (Fernet).
# Prefer a dedicated key; falls back to LLM_ENCRYPTION_KEY if unset.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# API_TOKEN_ENCRYPTION_KEY=
# Optional rate limits for /api/v1/external/*
# API_RATE_LIMIT_PER_MIN=60
# API_RATE_LIMIT_PER_DAY=5000

# Server
HOST=0.0.0.0
PORT=8000
