# Application
APP_NAME=AI Tribe: Motor Damage Assessment
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# Session cookie
SESSION_COOKIE_NAME=ai_tribe_session
SESSION_MAX_AGE=86400

# Database (local docker-compose defaults)
DATABASE_URL=postgresql+psycopg://ai_tribe:ai_tribe@localhost:5432/ai_tribe

# Storage
UPLOAD_DIR=data/uploads
MAX_IMAGES_PER_CLAIM=10
MAX_UPLOAD_MB=25

# Server
HOST=0.0.0.0
PORT=8000
